# Runtime config for the EHRPlus Client Portal container.
# Copy to deploy/portal.env and fill in. deploy/*.env is gitignored — never commit secrets.

# Public origin the portal is served at. Passkeys (WebAuthn) are BOUND to this origin,
# so it must exactly match the address users hit (the gateway host). Wrong value = login breaks.
BETTER_AUTH_URL=https://mobile.ehrnepal.com
PASSKEY_RP_ID=mobile.ehrnepal.com
PASSKEY_ORIGIN=https://mobile.ehrnepal.com

# Secrets. Generate each with:  openssl rand -base64 48
# JWT_SECRET signs/verifies the per-hospital access tokens this app mints (internal).
JWT_SECRET=
# BETTER_AUTH_SECRET signs app-account sessions. Keep stable, or everyone is logged out.
BETTER_AUTH_SECRET=

# Port the container listens on (host networking). The gateway forwards to this.
PORT=8973
